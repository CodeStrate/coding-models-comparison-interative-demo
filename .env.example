# -----------------------------------------------------------------------------
# Vault → manifest source path. Read by scripts/build-content.ts.
# -----------------------------------------------------------------------------
VAULT_ROOT=

# -----------------------------------------------------------------------------
# Private fork only — swap in src/App.dev.tsx at build time. The public build
# resolves the `~app` Vite alias to src/App.tsx and never references the dev
# entry. Set this to "true" in a private fork that has src/App.dev.tsx + the
# src/devtools/ module on disk.
# -----------------------------------------------------------------------------
VITE_USE_DEVTOOLS=

# -----------------------------------------------------------------------------
# /dev mini editor (only meaningful when VITE_USE_DEVTOOLS=true).
# Salted-key gate; edits stay in localStorage.
#
# Compute the hash:
#   node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]+':'+process.argv[2]).digest('hex'))" YOUR_SALT YOUR_KEY
#
# Activate:
#   /dev?key=YOUR_KEY  (param is stripped from history immediately after match)
# -----------------------------------------------------------------------------
VITE_DEV_SALT=
VITE_DEV_KEY_HASH=
